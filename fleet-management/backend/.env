# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database - UPDATE THESE WITH YOUR POSTGRESQL CREDENTIALS
DB_HOST=localhost
DB_PORT=5433
DB_NAME=fleet_management
DB_USER=postgres
DB_PASSWORD=12345678

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=fleet_super_secret_jwt_key_2024_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# GPS Servers
TCP_PORT=5000
# MQTT_BROKER_URL=mqtt://localhost:1883  # Uncomment when you have an MQTT broker
MQTT_USERNAME=
MQTT_PASSWORD=

# Email (optional - leave blank to skip email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Fleet System <noreply@fleet.com>

# SMS Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Maps
GOOGLE_MAPS_API_KEY=

# Encryption
ENCRYPTION_KEY=32charencryptionkeychangethis123
